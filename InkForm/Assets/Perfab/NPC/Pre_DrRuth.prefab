  m_Script: {fileID: 11500000, guid: e60fad9423fe9404b9acda74f7518c1f, type: 3}
  m_Name:
  m_EditorClassIdentifier:
  npcName: Dr. Ruth
  npcID: ruth_ch1
  canInteract: 1
  interactRange: 3
  dialogueAsset: {fileID: 0}
  mode: 0
  linearLines:
  - So. You found your way here. I hoped you would.
  - Don't be afraid. I'm not here to stop you.
  - "To them, you are K-02 - a prototype. An instrument of the Protocol."
  - But I made you. I watched you become someone. I consider you my child.
  - There is another. Your sister, Mary. They keep her isolated in the Nurserie.
  - "As your mother, I ask you: go to her. See her. Let her know she is not alone."
  - Break the window behind me, and drop to the factory floor.
  - Hide among the workers on the line. Move as they move. That is your only road
    to the Nurserie.
  - Go now, before they understand what you've become.
  branchA_Lines: []
  branchB_Lines: []
  textSpeed: 0.05
